// Models related to the user, api access, and sessions

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  ApiKey       ApiKey?
  Recipes      Recipe[]
}

model ApiKey {
  apiKey String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique
}

model PasswordResetToken {
  id        String   @id @default(uuid())  // Unique reset token ID
  token     String   @unique               // Secure reset token
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique               // Ensure one active token per user
  expiresAt DateTime                        // Expiration time for security
}
